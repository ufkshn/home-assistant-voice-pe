# Copy the keys you need into your ESPHome secrets.yaml
# (in the ESPHome add-on that is /config/esphome/secrets.yaml).
# secrets.yaml itself is gitignored — never commit real values.

# --- Wi-Fi (both firmware variants) ---
wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"

# --- OTA upload password (both variants) ---
# Set this to the SAME password your current firmware uses so wireless
# updates keep working without a USB re-flash. For a brand-new flash, pick
# any value; it becomes the OTA password after the first USB install.
ota_password: "choose-an-ota-password"

# --- Home Assistant native API encryption key (device appears in HA) ---
# Generate a fresh 32-byte base64 key, e.g. `openssl rand -base64 32`, or let
# the ESPHome dashboard generate one for you. Paste the SAME key into Home
# Assistant when it asks you to add the discovered device.
api_key: "PASTE_A_32_BYTE_BASE64_KEY_HERE="

# --- Private component repo (both variants) ---
# Tokenized git URL so ESPHome Builder can pull the va_client component from
# this private repo. Use a GitHub fine-grained PAT with access to this repo and
# Contents: Read-only (or a classic token with the full `repo` scope). No angle
# brackets, no spaces.
va_components_repo: "https://github_pat_xxxxxxxx@github.com/xandervanerven/home-assistant-voice-pe.git"

# --- Static IP (ONLY for home-assistant-voice.realtime.static-ip.yaml) ---
# The standard home-assistant-voice.realtime.yaml uses DHCP and ignores these.
# Set these to the fixed IP you want for the device + your router's gateway,
# subnet mask, and DNS servers. (Placeholders below — use your own LAN values.)
static_ip: "192.168.1.50"
gateway: "192.168.1.1"
subnet: "255.255.255.0"
dns1: "1.1.1.1"
dns2: "1.0.0.1"
